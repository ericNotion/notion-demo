{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"],
      "@/root/*": ["./src/app/(root)/*"],
      "@/nds/*": ["./src/nds/*"],
      "@nds-icons": ["./src/nds-icons/index.ts"],
      "@nds-icons/icon-manifest": ["./src/nds-icons/icon-manifest.ts"],
      "@nds-icons/icon-import-map": ["./src/nds-icons/icon-import-map.ts"],
      "@nds-icons/*": ["./src/nds-icons/src/*"],
      "@/eric/*": ["./src/app/eric/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
