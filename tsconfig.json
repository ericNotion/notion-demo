{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"],
      "@/root/*": ["./src/app/(root)/*"],
      "@/templates/*": ["./src/app/(templates)/templates/*"],
      "@/nds/*": ["./src/nds/*"],
      "@nds-icons": ["./src/nds-icons/index.ts"],
      "@nds-icons/icon-manifest": ["./src/nds-icons/icon-manifest.ts"],
      "@nds-icons/icon-import-map": ["./src/nds-icons/icon-import-map.ts"],
      "@nds-icons/*": ["./src/nds-icons/src/*"],
      "@noticons": ["./src/noticons/index.ts"],
      "@noticons/icon-manifest": ["./src/noticons/icon-manifest.ts"],
      "@noticons/icon-import-map": ["./src/noticons/icon-import-map.ts"],
      "@noticons/*": ["./src/noticons/src/*"],
      "@/jclem/*": ["./src/app/jclem/*"],
      "@/brian/*": ["./src/app/brian/*"],
      "@/randy/*": ["./src/app/randy/*"],
      "@/kathy/*": ["./src/app/kathy/*"],
      "@/jin/*": ["./src/app/jin/*"],
      "@/joseph/*": ["./src/app/joseph/*"],
      "@/nut/*": ["./src/app/nut/*"],
      "@/shannon/*": ["./src/app/shannon/*"],
      "@/boss/*": ["./src/app/boss/*"],
      "@/wustep/*": ["./src/app/wustep/*"],
      "@/cole/*": ["./src/app/cole/*"],
      "@/kelly/*": ["./src/app/kelly/*"],
      "@/sbcatania/*": ["./src/app/sbcatania/*"],
      "@/gyzhang328/*": ["./src/app/gyzhang328/*"],
      "@/kai/*": ["./src/app/kai/*"],
      "@/mj/*": ["./src/app/mj/*"],
      "@/wdawson/*": ["./src/app/wdawson/*"],
      "@/madeleine/*": ["./src/app/madeleine/*"],
      "@/ein/*": ["./src/app/ein/*"],
      "@/ivann/*": ["./src/app/ivann/*"],
      "@/frank/*": ["./src/app/frank/*"],
      "@/seth/*": ["./src/app/seth/*"],
      "@/eric/*": ["./src/app/eric/*"],
      "@/sergio/*": ["./src/app/sergio/*"],
      "@/paul/*": ["./src/app/paul/*"],
      "@/porchfire/*": ["./src/app/porchfire/*"],
      "@/dtsao/*": ["./src/app/dtsao/*"],
      "@/tnguyen/*": ["./src/app/tnguyen/*"],
      "@/marina/*": ["./src/app/marina/*"],
      "@/sayaiwasaki/*": ["./src/app/sayaiwasaki/*"],
      "@/amitsankaran/*": ["./src/app/amitsankaran/*"],
      "@/youyang/*": ["./src/app/youyang/*"],
      "@/em/*": ["./src/app/em/*"],
      "@/jenna/*": ["./src/app/jenna/*"],
      "@/jeslyn/*": ["./src/app/jeslyn/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
